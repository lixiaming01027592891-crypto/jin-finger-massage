---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = '金手指按摩｜24小時專業按摩養生會館｜腳底按摩 全身指壓 精油油壓';
const description = '金手指按摩提供24小時專業按摩服務，包括腳底按摩、全身指壓、精油油壓、肩頸舒壓。專業師傅、舒適環境，全年無休。立即預約享受極致放鬆！';
const keywords = '24小時按摩,腳底按摩,全身按摩,指壓,油壓,肩頸按摩,按摩推薦,養生會館,台北按摩,深夜按摩,金手指';

const services = [
  {
    id: 'foot',
    title: '腳底按摩',
    subtitle: 'Foot Massage',
    description: '針對足底反射區進行深度調理，疏通經絡、促進循環、緩解疲勞。專業師傅精準掌握穴位，讓雙腳重拾輕盈。',
    duration: '60 / 90 分鐘',
    image: '/images/service-foot.jpg',
    features: ['足底反射區調理', '中藥足浴泡腳', '經絡疏通'],
  },
  {
    id: 'body',
    title: '全身指壓',
    subtitle: 'Body Acupressure',
    description: '沿著人體經絡穴位進行深度指壓，針對肩頸腰背等容易緊繃的部位加強調理，釋放深層壓力。',
    duration: '60 / 90 / 120 分鐘',
    image: '/images/service-body.jpg',
    features: ['經絡穴位指壓', '深度筋膜放鬆', '全身經脈調理'],
  },
  {
    id: 'oil',
    title: '精油油壓',
    subtitle: 'Aromatherapy Oil Massage',
    description: '嚴選天然精油搭配專業油壓手法，溫潤肌膚的同時舒緩身心靈。五款精油任選，客製化您的放鬆體驗。',
    duration: '60 / 90 / 120 分鐘',
    image: '/images/service-oil.jpg',
    features: ['天然植萃精油', '淋巴引流手法', '全身深層舒壓'],
  },
  {
    id: 'shoulder',
    title: '肩頸舒壓',
    subtitle: 'Neck & Shoulder Relief',
    description: '專為上班族設計的肩頸專區調理，針對長期久坐、姿勢不良造成的肩頸僵硬進行重點舒緩。',
    duration: '30 / 60 分鐘',
    image: '/images/service-shoulder.jpg',
    features: ['肩頸筋膜放鬆', '頭部穴位按摩', '上背經絡調理'],
  },
];

const features = [
  { icon: 'clock', title: '24小時營業', desc: '全年無休，隨時為您服務' },
  { icon: 'award', title: '專業師傅', desc: '十年以上經驗認證師傅' },
  { icon: 'home', title: '舒適環境', desc: '獨立包廂，隱私有保障' },
  { icon: 'heart', title: '以客為尊', desc: '客製化服務，滿足需求' },
];

const testimonials = [
  { name: '王先生', role: '上班族', text: '長期坐辦公室肩頸僵硬，來金手指按摩後整個人輕鬆很多。師傅手法專業，環境也很舒適。', rating: 5 },
  { name: '李小姐', role: '業務主管', text: '24小時營業真的很方便，加班後來放鬆一下，隔天精神飽滿。已經推薦給好多同事了！', rating: 5 },
  { name: '張先生', role: '自由業', text: '腳底按摩按得很到位，泡腳的中藥湯也很講究。整體服務品質在台北數一數二。', rating: 5 },
];

const faqs = [
  { q: '需要事先預約嗎？', a: '建議提前預約以確保座位，但我們也接受現場客人。24小時營業，隨時歡迎您。' },
  { q: '有哪些付款方式？', a: '我們接受現金、信用卡、LINE Pay、街口支付等多種付款方式。' },
  { q: '有提供停車位嗎？', a: '店門前可停汽機車，附近也有收費停車場。' },
  { q: '男女客人都接受嗎？', a: '是的，我們歡迎所有客人，並提供專業、安全的服務環境。' },
  { q: '按摩會痛嗎？', a: '師傅會根據您的耐受度調整力道，隨時可以溝通。我們追求「痠中帶爽」的舒適體驗。' },
  { q: '有什麼注意事項？', a: '孕婦、心血管疾病患者、皮膚發炎或有傷口者，請先告知師傅或諮詢醫師建議。' },
];
---

<Layout title={title} description={description} keywords={keywords}>
  <Navbar />
  
  <!-- HERO SECTION -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden aurora-bg" aria-label="網站首頁主視覺">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img 
        src="/images/hero-bg.jpg" 
        alt="金手指按摩店內環境" 
        class="w-full h-full object-cover scale-105 animate-scale-in"
        loading="eager"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-stone-950/60"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-stone-950/40 via-transparent to-stone-950"></div>
    </div>

    <!-- Floating Particles -->
    <div class="particle" style="top: 20%; left: 10%; animation-delay: 0s;"></div>
    <div class="particle" style="top: 30%; right: 15%; animation-delay: 2s; width: 4px; height: 4px;"></div>
    <div class="particle" style="top: 60%; left: 20%; animation-delay: 4s;"></div>
    <div class="particle" style="top: 70%; right: 25%; animation-delay: 1s; width: 2px; height: 2px;"></div>
    <div class="particle" style="top: 40%; left: 80%; animation-delay: 3s;"></div>
    <div class="particle" style="top: 15%; left: 50%; animation-delay: 5s; width: 5px; height: 5px;"></div>
    <div class="particle" style="top: 80%; left: 60%; animation-delay: 6s;"></div>
    <div class="particle" style="top: 50%; left: 5%; animation-delay: 7s; width: 3px; height: 3px;"></div>

    <!-- Glass Card Container -->
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto pt-20">
      <!-- Glassmorphism Card -->
      <div class="animate-fade-in bg-stone-950/30 backdrop-blur-sm border border-gold-500/10 rounded-3xl px-6 py-10 sm:px-12 sm:py-14 md:px-16 md:py-18">
        
        <!-- Top Badge -->
        <div class="animate-fade-in-delay mb-6">
          <span class="inline-flex items-center gap-2 px-5 py-2 bg-gold-500/8 border border-gold-500/20 rounded-full text-gold-300 text-sm tracking-widest font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-gold-400 animate-pulse"></span>
            24 HOURS / 365 DAYS
          </span>
        </div>

        <!-- Gold Line -->
        <div class="glow-line max-w-[120px] mx-auto mb-8 animate-fade-in-delay"></div>

        <!-- Main Title: 金手指 with Aurora Effect -->
        <h1 class="animate-fade-in-delay text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-bold mb-3 leading-none tracking-wider">
          <span class="aurora-text">金手指</span>
        </h1>

        <!-- Subtitle -->
        <p class="animate-fade-in-delay-2 text-xl sm:text-2xl md:text-3xl text-stone-200 mb-2 font-light tracking-[0.3em] uppercase">
          Golden Finger
        </p>
        <p class="animate-fade-in-delay-2 text-base sm:text-lg text-stone-400 mb-3 font-light tracking-wider">
          專業按摩養生會館
        </p>

        <!-- Gold Line -->
        <div class="glow-line max-w-[80px] mx-auto my-6 animate-fade-in-delay-2"></div>

        <!-- Description -->
        <p class="animate-fade-in-delay-3 text-stone-400 max-w-xl mx-auto mb-10 leading-relaxed text-sm sm:text-base">
          腳底按摩 · 全身指壓 · 精油油壓 · 肩頸舒壓<br class="hidden sm:block">
          專業師傅、舒適環境，隨時為您釋放一天的疲憊
        </p>

        <!-- CTA Buttons -->
        <div class="animate-fade-in-delay-3 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+886-2-XXXX-XXXX" class="btn-primary text-base sm:text-lg flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            立即電話預約
          </a>
          <a href="#services" class="btn-outline text-base sm:text-lg flex items-center justify-center gap-2">
            探索服務項目
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
        </div>

        <!-- Scroll Indicator -->
        <div class="mt-10 animate-fade-in-delay-3">
          <div class="animate-bounce inline-block">
            <svg class="text-gold-400/40" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES BAR -->
  <section class="bg-stone-900 border-y border-stone-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {features.map(f => (
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-gold-500/10 flex items-center justify-center">
              {f.icon === 'clock' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
              {f.icon === 'award' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>}
              {f.icon === 'home' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>}
              {f.icon === 'heart' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>}
            </div>
            <h3 class="text-gold-300 font-semibold text-sm mb-1">{f.title}</h3>
            <p class="text-stone-500 text-xs">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section id="services" class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Our Services</span>
        <h2 class="section-title mt-2">專業按摩服務</h2>
        <p class="section-subtitle">針對不同需求提供客製化的放鬆體驗，讓身心靈回歸平衡</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {services.map((service, i) => (
          <div class="card-glass overflow-hidden group hover:border-gold-500/30 transition-all duration-500">
            <div class="relative h-56 overflow-hidden">
              <img 
                src={service.image} 
                alt={`${service.title}服務`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
                width="600"
                height="400"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-stone-950 via-stone-950/20 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <span class="text-gold-400 text-xs tracking-wider">{service.subtitle}</span>
                <h3 class="text-2xl font-bold text-white">{service.title}</h3>
              </div>
            </div>
            <div class="p-6">
              <p class="text-stone-400 text-sm leading-relaxed mb-4">{service.description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {service.features.map(feat => (
                  <span class="px-3 py-1 bg-gold-500/10 text-gold-400 text-xs rounded-full">{feat}</span>
                ))}
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-stone-800/50">
                <span class="text-stone-500 text-sm">
                  <svg class="inline mr-1" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {service.duration}
                </span>
                <a href={`/services#${service.id}`} class="text-gold-400 text-sm hover:text-gold-300 transition-colors flex items-center gap-1">
                  了解詳情 <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="py-20 md:py-28 bg-stone-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-gold-500 text-sm tracking-widest uppercase">About Us</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gold-300 mt-2 mb-6">為什麼選擇金手指？</h2>
          <div class="space-y-4 text-stone-400 leading-relaxed">
            <p>金手指按摩成立多年來，始終堅持「以客為尊、以人為貴」的服務理念。我們深知現代人生活壓力大、工作節奏快，因此提供<strong class="text-stone-200">24小時全年無休</strong>的專業按摩服務，讓您無論何時都能找到放鬆的避風港。</p>
            <p>我們的師傅皆具備<strong class="text-stone-200">十年以上專業經驗</strong>，精通中式指壓、經絡調理、精油芳療等多種技法。每位師傅都經過嚴格的技術考核與服務培訓，確保為您提供最安全、舒適的按摩體驗。</p>
            <p>店內環境採用<strong class="text-stone-200">現代東方質感設計</strong>，每間包廂皆為獨立空間，配備舒適按摩床、柔和燈光與舒壓音樂，讓您在私密、安心的環境中徹底放鬆。</p>
          </div>
          <a href="/about" class="btn-primary inline-flex items-center gap-2 mt-8">
            了解更多 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl shadow-gold-500/10">
            <img src="/images/about-therapist.jpg" alt="金手指按摩專業師傅" class="w-full h-auto" loading="lazy" width="600" height="800" />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-stone-900 border border-gold-500/20 rounded-xl p-4 shadow-xl">
            <div class="text-3xl font-bold text-gold-400">10+</div>
            <div class="text-stone-400 text-sm">年專業經驗</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ENVIRONMENT PREVIEW -->
  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Environment</span>
        <h2 class="section-title mt-2">舒適環境</h2>
        <p class="section-subtitle">精心打造的放鬆空間，讓您從踏入的那一刻起就感受到身心的轉變</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-2xl overflow-hidden group">
          <img src="/images/env-room1.jpg" alt="金手指按摩獨立包廂" class="w-full h-72 md:h-80 object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" width="800" height="500" />
        </div>
        <div class="rounded-2xl overflow-hidden group">
          <img src="/images/env-room2.jpg" alt="金手指按摩休息區" class="w-full h-72 md:h-80 object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" width="800" height="500" />
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/environment" class="btn-outline inline-flex items-center gap-2">
          查看更多環境照片 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-20 md:py-28 bg-stone-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Testimonials</span>
        <h2 class="section-title mt-2">顧客好評</h2>
        <p class="section-subtitle">來自真實顧客的回饋，是我們持續進步的動力</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="card-glass p-6">
            <div class="flex gap-1 mb-4">
              {Array.from({length: t.rating}).map(() => (
                <svg class="text-gold-400 fill-gold-400" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-stone-300 text-sm leading-relaxed mb-4">"{t.text}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-stone-800/50">
              <div class="w-10 h-10 rounded-full bg-gold-500/20 flex items-center justify-center text-gold-400 font-bold">{t.name[0]}</div>
              <div>
                <div class="text-stone-200 text-sm font-medium">{t.name}</div>
                <div class="text-stone-500 text-xs">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section id="faq" class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">FAQ</span>
        <h2 class="section-title mt-2">常見問題</h2>
        <p class="section-subtitle">整理了我們最常收到的問題，幫助您更快了解我們的服務</p>
      </div>
      <div class="space-y-4">
        {faqs.map((faq, i) => (
          <details class="card-glass group" name="faq">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
              <span class="text-stone-200 font-medium text-left flex-1 pr-4">{faq.q}</span>
              <svg class="text-gold-500 flex-shrink-0 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="px-5 pb-5 text-stone-400 text-sm leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
