---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = '關於金手指｜品牌故事與專業團隊 - 24小時按摩養生會館';
const description = '了解金手指按摩的品牌故事與經營理念。十年以上專業師傅團隊，24小時全年無休，以客為尊的服務精神，為您提供最優質的按摩體驗。';
const keywords = '金手指按摩,品牌故事,按摩師傅,專業團隊,24小時按摩,養生會館';

const milestones = [
  { year: '2015', title: '品牌創立', desc: '金手指按摩在台北創立，以專業腳底按摩起家' },
  { year: '2017', title: '服務升級', desc: '新增全身指壓與精油油壓服務，滿足多元需求' },
  { year: '2019', title: '24小時營業', desc: '轉型為24小時全年無休，隨時服務顧客' },
  { year: '2021', title: '環境翻新', desc: '全面裝修升級，打造現代東方質感空間' },
  { year: '2024', title: '口碑肯定', desc: '累積超過3000則五星好評，成為台北知名按摩品牌' },
];

const values = [
  { icon: 'users', title: '以客為尊', desc: '每位顧客都是貴賓，用心聆聽您的需求' },
  { icon: 'award', title: '專業至上', desc: '師傅持續進修，精進技術與服務品質' },
  { icon: 'shield', title: '安全衛生', desc: '嚴格消毒把關，使用一次性用品確保衛生' },
  { icon: 'heart', title: '用心服務', desc: '從細節出發，讓每次體驗都超越期待' },
];

const team = [
  { name: '陳師傅', role: '資深按摩師', exp: '15年經驗', specialty: '全身指壓、經絡調理', desc: '精通人體經絡走向，手法精準到位，深受顧客喜愛。' },
  { name: '林師傅', role: '首席芳療師', exp: '12年經驗', specialty: '精油油壓、淋巴引流', desc: '具備國際芳療認證，擅長依顧客狀態調配精油。' },
  { name: '王師傅', role: '腳底按摩師', exp: '10年經驗', specialty: '足底反射區調理', desc: '對足底穴位瞭若指掌，能有效緩解各種不適。' },
  { name: '張師傅', role: '肩頸調理師', exp: '8年經驗', specialty: '肩頸舒壓、頭部按摩', desc: '專精肩頸調理，幫助無數上班族擺脫痠痛困擾。' },
];
---

<Layout title={title} description={description} keywords={keywords} canonical="/about">
  <Navbar />
  
  <!-- Page Header -->
  <section class="pt-32 pb-12 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-gold-900/10 to-stone-950"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-500 text-sm tracking-widest uppercase">About Us</span>
      <h1 class="text-4xl md:text-5xl font-bold text-gold-300 mt-2 mb-4">關於金手指</h1>
      <p class="text-stone-400 max-w-2xl mx-auto">十年堅持，只為給您最好的按摩體驗</p>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-2xl overflow-hidden shadow-2xl shadow-gold-500/5">
          <img src="/images/about-therapist.jpg" alt="金手指按摩師傅專業團隊" class="w-full h-auto" loading="lazy" width="600" height="800" />
        </div>
        <div>
          <span class="text-gold-500 text-sm tracking-wider">Our Story</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gold-300 mt-2 mb-6">品牌故事</h2>
          <div class="space-y-4 text-stone-400 leading-relaxed">
            <p>金手指按摩創立於2015年，創辦人懷著對傳統按摩技藝的熱愛，以及希望幫助現代人舒緩身心壓力的初衷，在台北開設了第一家店面。</p>
            <p>從最初的腳底按摩專門店，逐步發展為提供全方位按摩服務的養生會館。我們始終堅持「<strong class="text-stone-200">以客為尊、以人為貴</strong>」的經營理念，將每位顧客視為珍貴的貴賓。</p>
            <p>2019年，我們轉型為<strong class="text-stone-200">24小時全年無休</strong>的營業模式，希望能陪伴無論是加班到深夜的上班族、還是作息特殊的族群，在任何時刻都能找到放鬆身心之所。</p>
            <p>多年來，金手指按摩累積了無數顧客的信任與好評。我們將持續精進服務品質，為更多人帶來健康與放鬆的美好體驗。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section class="py-16 bg-stone-900/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Milestones</span>
        <h2 class="section-title mt-2">發展里程碑</h2>
      </div>
      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gold-500/20"></div>
        <div class="space-y-12">
          {milestones.map((m, i) => (
            <div class={`relative flex items-start gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
              <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                <div class="card-glass p-5 inline-block">
                  <span class="text-gold-400 font-bold text-lg">{m.year}</span>
                  <h3 class="text-stone-200 font-medium mt-1">{m.title}</h3>
                  <p class="text-stone-500 text-sm mt-1">{m.desc}</p>
                </div>
              </div>
              <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-gold-500 mt-6"></div>
              <div class="flex-1 hidden md:block"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Our Values</span>
        <h2 class="section-title mt-2">經營理念</h2>
        <p class="section-subtitle">四大核心價值，引領我們持續前進</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map(v => (
          <div class="card-glass p-6 text-center">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold-500/10 flex items-center justify-center">
              {v.icon === 'users' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>}
              {v.icon === 'award' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>}
              {v.icon === 'shield' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {v.icon === 'heart' && <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>}
            </div>
            <h3 class="text-stone-200 font-medium mb-2">{v.title}</h3>
            <p class="text-stone-500 text-sm">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section id="team" class="py-16 bg-stone-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-gold-500 text-sm tracking-widest uppercase">Our Team</span>
        <h2 class="section-title mt-2">專業團隊</h2>
        <p class="section-subtitle">經驗豐富的師傅團隊，為您提供專業服務</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map(t => (
          <div class="card-glass overflow-hidden group">
            <div class="h-2 bg-gradient-to-r from-gold-500 to-gold-700"></div>
            <div class="p-6">
              <div class="w-16 h-16 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-400 font-bold text-xl mb-4">{t.name[0]}</div>
              <h3 class="text-stone-200 font-bold text-lg">{t.name}</h3>
              <p class="text-gold-400 text-sm mb-1">{t.role}</p>
              <p class="text-stone-500 text-xs mb-3">{t.exp}</p>
              <p class="text-stone-400 text-sm mb-3">{t.specialty}</p>
              <p class="text-stone-500 text-xs leading-relaxed">{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <p class="text-stone-500 text-sm">* 以上為部分師傅代表，實際服務師傅可能依時段調整</p>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-12 border-t border-stone-800/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-3">
        <svg class="text-gold-500" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="text-stone-300 font-medium">貼心提醒</span>
      </div>
      <p class="text-stone-500 text-sm leading-relaxed">
        金手指按摩提供的服務為<strong class="text-stone-400">放鬆舒壓</strong>之保健養生服務，非醫療行為。<br>
        本服務無法取代專業醫療診斷與治療，如有身體不適請諮詢專業醫師。<br>
        效果因人而異，個人經驗不代表所有人的體驗結果。
      </p>
    </div>
  </section>

  <Footer />
</Layout>
