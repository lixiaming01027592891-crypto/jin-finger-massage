---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = '部落格｜金手指按摩 - 按摩知識、養生保健、舒壓技巧';
const description = '金手指按摩部落格即將上線，敬請期待專業按摩知識、養生保健秘訣與舒壓技巧分享。';
const keywords = '按摩知識,按摩部落格,台北按摩推薦,養生保健,舒壓技巧';

const comingSoon = [
  { title: '台北按摩推薦｜深夜疲勞？24小時按摩會館讓你隨時放鬆', category: '台北按摩推薦' },
  { title: '腳底按摩的好處｜你不知道的足底反射區秘密', category: '按摩知識' },
  { title: '肩頸痠痛怎麼辦？上班族必看肩頸舒壓完整指南', category: '舒壓技巧' },
  { title: '精油按摩怎麼選？五種精油功效完整介紹與推薦', category: '精油知識' },
  { title: '第一次按摩要注意什麼？新手必讀按摩會館完整攻略', category: '按摩入門' },
];
---

<Layout title={title} description={description} keywords={keywords} canonical="/blog">
  <Navbar />
  
  <!-- Page Header -->
  <section class="pt-32 pb-12 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-gold-900/10 to-stone-950"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-500 text-sm tracking-widest uppercase">Blog</span>
      <h1 class="text-4xl md:text-5xl font-bold text-gold-300 mt-2 mb-4">按摩知識部落格</h1>
      <p class="text-stone-400 max-w-2xl mx-auto">專業按摩知識、養生保健秘訣、舒壓技巧分享</p>
    </div>
  </section>

  <!-- Coming Soon -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      
      <div class="card-glass p-12 mb-12">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gold-500/10 flex items-center justify-center">
          <svg class="text-gold-400" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gold-300 mb-3">精彩內容即將上架</h2>
        <p class="text-stone-400 mb-2">我們正在準備高品質的按摩知識文章</p>
        <p class="text-stone-500 text-sm">敬請期待，文章上線後將第一時間與您分享</p>
      </div>

      <!-- Article Preview List -->
      <div class="text-left space-y-4">
        <h3 class="text-stone-300 font-medium mb-6 text-center">預計上架文章</h3>
        {comingSoon.map((post, i) => (
          <div class="card-glass p-5 flex items-center gap-4 opacity-60">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 flex items-center justify-center text-gold-500 text-sm font-bold flex-shrink-0">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="flex-1 min-w-0">
              <span class="text-gold-500/60 text-xs">{post.category}</span>
              <p class="text-stone-400 text-sm truncate">{post.title}</p>
            </div>
            <span class="text-stone-600 text-xs flex-shrink-0">即將上架</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-stone-900/50 border-t border-stone-800/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gold-300 mb-4">想親身體驗？</h2>
      <p class="text-stone-400 mb-8">不如先來金手指按摩，感受專業師傅的手藝。24小時營業，隨時歡迎。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/services" class="btn-primary flex items-center justify-center gap-2">查看服務項目</a>
        <a href="/contact" class="btn-outline">聯絡我們</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
